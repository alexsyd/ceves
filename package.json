{
  "name": "ceves",
  "version": "0.1.0",
  "description": "Event Sourcing framework for Cloudflare Workers and Durable Objects with CQRS and OpenAPI routing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "GETTING_STARTED.md",
    "docs/api",
    "example/src",
    "example/README.md",
    "example/wrangler.toml",
    "example/wrangler-do.toml",
    "example/tsconfig.json",
    "example/package.json",
    "example/migrations"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "event-sourcing",
    "cqrs",
    "cloudflare-workers",
    "durable-objects",
    "typescript",
    "r2",
    "d1",
    "serverless",
    "event-store",
    "openapi"
  ],
  "author": "Alex Sydorenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexsyd/ceves.git"
  },
  "homepage": "https://github.com/alexsyd/ceves#readme",
  "bugs": {
    "url": "https://github.com/alexsyd/ceves/issues"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.7",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "chanfana": "^2.8.3",
    "hono": "^4.10.6",
    "jose": "^5.0.0",
    "zod": "^3.25.76"
  }
}
